# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=some_random_secure_string_for_webhook_security
ALLOWED_USER_IDS=123456789,987654321
# Optional: Custom Telegram API proxy/base URL (e.g. Cloudflare Worker URL to bypass domain block)
# TELEGRAM_API_BASE_URL=https://your-worker-name.your-subdomain.workers.dev/bot
# Optional: Set to true if deploying on private Hugging Face Space to use polling instead of webhooks
# TELEGRAM_POLLING=false
# Optional: Proxy for Instagram scraping (to bypass Instagram cloud IP blocks on Hugging Face)
# SCRAPER_PROXY=http://username:password@your-proxy-address:port

# APIFY Token for scraping Instagram
APIFY_API_TOKEN=your_apify_api_token_here

# Optional: Free block bypass using Instagram web session cookies
# INSTAGRAM_SESSION_ID=your_sessionid_cookie_value
# INSTAGRAM_USER_ID=your_ds_user_id_cookie_value

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_from_google_ai_studio

# Groq AI API
GROQ_API_KEY=your_groq_api_key_from_groq_console

# Google Sheets Config
# Base64 encoded Service Account JSON credentials
GOOGLE_CREDS_JSON=your_base64_encoded_service_account_json
GOOGLE_SHEET_ID=your_google_sheet_id_from_url

# Space Deployment Configuration
HF_SPACE_URL=https://your-username-your-space-name.hf.space
LOG_LEVEL=INFO
